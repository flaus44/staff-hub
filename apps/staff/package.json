{
  "name": "@flaus/staff",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev --port 3000",
    "bug-hunt": "node scripts/bug-hunt.mjs",
    "onboarding-smoke": "node scripts/onboarding-smoke.mjs",
    "reset-admin": "cross-env NODE_OPTIONS=--no-deprecation payload run src/scripts/resetAdmin.ts",
    "upsert:org-settings": "cross-env NODE_OPTIONS=--no-deprecation payload run src/scripts/upsertOrgSettings.ts",
    "cleanup-legacy-onboarding-tasks": "cross-env NODE_OPTIONS=--no-deprecation payload run scripts/cleanup-legacy-onboarding-tasks.ts",
    "discover:onboarding-pdf-fields": "cross-env NODE_OPTIONS=--no-deprecation payload run scripts/discover-pdf-fields.ts",
    "check:onboarding-pdf-field-maps": "cross-env NODE_OPTIONS=--no-deprecation payload run scripts/check-onboarding-form-field-maps.ts",
    "schedule:ceis-redelivery": "cross-env NODE_OPTIONS=--no-deprecation payload run scripts/schedule-ceis-redelivery.ts",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "generate:codesign-cheat-sheet": "npx tsx scripts/generate-codesign-cheat-sheet.mjs",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test --config=e2e/playwright.config.ts"
  },
  "dependencies": {
    "@flaus/ui-forms": "*",
    "@hookform/resolvers": "^5.0.0",
    "@payloadcms/db-postgres": "3.81.0",
    "@payloadcms/next": "3.81.0",
    "@payloadcms/richtext-lexical": "3.81.0",
    "@payloadcms/ui": "3.81.0",
    "bcryptjs": "^3.0.2",
    "graphql": "^16.8.2",
    "jose": "5.10.0",
    "next": "^16.2.1",
    "otplib": "^12.0.1",
    "payload": "3.81.0",
    "pdf-lib": "^1.17.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.55.0",
    "sharp": "0.34.2",
    "signature_pad": "^5.0.1",
    "uuid": "^11.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "22.19.9",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/uuid": "^10.0.0",
    "cross-env": "^7.0.3",
    "tailwindcss": "^4.0.0",
    "typescript": "5.7.3"
  }
}
