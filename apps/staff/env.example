DATABASE_URL=postgres://postgres:postgres@localhost:5433/staff_hub
PAYLOAD_SECRET=replace-with-a-strong-secret
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
# Production (via www.flaus.com.au/staff): https://www.flaus.com.au/staff
# NEXT_PUBLIC_BASE_PATH=/staff  # optional override; defaults to /staff in production builds
TFN_ENCRYPTION_KEY=replace-with-32-byte-key
BANK_ENCRYPTION_KEY=replace-with-32-byte-key
MFA_ENFORCE=false

# Optional contract identity verification track
DIDIT_API_KEY=
DIDIT_WORKFLOW_ID=
DIDIT_API_URL=https://verification.didit.me

# Optional local seed/admin overrides
SEED_ADMIN_EMAIL=admin@flaus.com.au
SEED_ADMIN_PASSWORD=changeme
